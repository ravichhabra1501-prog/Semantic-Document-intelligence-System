# Copy this file to .env and fill in the values for local development.
# Azure PostgreSQL Flexible Server usually requires SSL:
# PGSSLMODE=require
# DATABASE_URL=postgresql://user:password@host:5432/mydb?sslmode=require

DATABASE_URL=
# Microsoft Entra ID
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_API_SCOPE=api://<client-id>/access_as_user
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_API_AUDIENCE=api://<client-id>
ENTRA_API_SCOPE=access_as_user

# Optional: set when frontend and API are hosted on different origins.
# Example: https://your-api-host.example.com
VITE_API_BASE_URL=

# Optional: comma-separated allowlist for browser origins calling the API.
# Example: https://semantic-doc-intel-system.netlify.app,http://localhost:5173
CORS_ORIGIN=
