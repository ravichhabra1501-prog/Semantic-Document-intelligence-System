# Copy this file to .env and fill in the values for local development.
DATABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_AUTH_ENDPOINT=https://<project-ref>.supabase.co/auth/v1/authorize
VITE_SUPABASE_TOKEN_ENDPOINT=https://<project-ref>.supabase.co/auth/v1/token
VITE_SUPABASE_OAUTH_PROVIDER=
VITE_SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set when frontend and API are hosted on different origins.
# Example: https://your-api-host.example.com
VITE_API_BASE_URL=

# Optional: comma-separated allowlist for browser origins calling the API.
# Example: https://semantic-doc-intel-system.netlify.app,http://localhost:5173
CORS_ORIGIN=
